<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="@dimen/post_margin_horizontal"
    android:layout_marginVertical="@dimen/post_margin_vertical">

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/image_compact_preview"
        android:layout_width="72dp"
        android:layout_height="72dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:scaleType="centerCrop"
        app:shapeAppearanceOverlay="@style/RoundedImageViewStyle"
        android:contentDescription="@null"
        tools:src="@tools:sample/backgrounds/scenic"/>

    <com.omeron.ui.common.widget.CardButton
        android:id="@+id/button_compact_type_indicator"
        android:layout_width="@dimen/app_bar_button_size"
        android:layout_height="@dimen/app_bar_button_size"
        app:layout_constraintStart_toStartOf="@id/image_compact_preview"
        app:layout_constraintBottom_toBottomOf="@id/image_compact_preview"
        android:layout_margin="@dimen/post_type_indicator_margin"
        android:focusable="false"
        android:clickable="false"
        style="@style/CardButtonStyle"
        tools:icon="@drawable/ic_play"/>

    <TextView
        android:id="@+id/text_compact_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:maxLines="3"
        android:ellipsize="end"
        android:textAppearance="@style/TextAppearancePostTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/image_compact_preview"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginEnd="12dp"
        tools:text="This is a compact post title that can wrap onto up to three lines before it ellipsizes"/>

    <TextView
        android:id="@+id/text_compact_info"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/post_margin_top_small"
        android:maxLines="1"
        android:ellipsize="end"
        android:textColor="@color/text_color_secondary"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/image_compact_preview"
        app:layout_constraintTop_toBottomOf="@id/text_compact_title"
        android:layout_marginEnd="12dp"
        tools:text="r/subreddit · 14.3k"/>

</androidx.constraintlayout.widget.ConstraintLayout>
