<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>
        <variable
            name="user"
            type="com.omeron.data.model.db.FollowedUser" />
    </data>

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="@dimen/subscriptions_card_height"
        style="@style/SubscriptionsCardStyle">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="@dimen/subscriptions_padding"
            android:background="@drawable/card_background">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/user_image"
                android:layout_width="@dimen/subscriptions_image_size"
                android:layout_height="@dimen/subscriptions_image_size"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:shapeAppearanceOverlay="@style/CircularImageViewStyle"
                tools:src="@tools:sample/avatars"/>

            <TextView
                android:id="@+id/user_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                app:layout_constraintLeft_toRightOf="@id/user_image"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@id/button_hide"
                android:layout_marginStart="@dimen/subscriptions_margin_horizontal"
                android:textAppearance="@style/TextAppearanceSubscription"
                android:text="@{user.name}"
                tools:text="username"/>

            <ImageButton
                android:id="@+id/button_hide"
                android:layout_width="@dimen/app_bar_button_size"
                android:layout_height="@dimen/app_bar_button_size"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@id/button_unfollow"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="@color/icon_tint"
                android:contentDescription="@string/toggle_visibility"
                app:srcCompat="@drawable/ic_visibility"/>

            <ImageButton
                android:id="@+id/button_unfollow"
                android:layout_width="@dimen/app_bar_button_size"
                android:layout_height="@dimen/app_bar_button_size"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="@color/icon_tint"
                android:contentDescription="@string/unfollow"
                app:srcCompat="@drawable/ic_close"/>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </com.google.android.material.card.MaterialCardView>

</layout>
